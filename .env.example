# Rakku Digital Police Assistant - Environment Configuration Template

# Gemini API Key (Required for AI assistant. Get one from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL database connection (Used by NestJS backend via Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rakku?schema=public"

# Ports and Endpoint Configurations
PORT=3001
AI_SERVICE_URL="http://localhost:8000"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001/api"

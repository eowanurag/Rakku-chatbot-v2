{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeprecationSubmission",
  "type": "OBJECT",
  "required": ["submissionType", "scenarioKey"],
  "properties": {
    "submissionType": {
      "type": "STRING",
      "enum": ["DEPRECATE"]
    },
    "scenarioKey": {
      "type": "STRING",
      "pattern": "^[A-Z0-9_]+$"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScenarioSubmission",
  "type": "OBJECT",
  "required": ["submissionType", "scenarioKey", "parentPath", "status", "owner", "workflow", "outcome", "knowledge", "playbook"],
  "properties": {
    "submissionType": {
      "type": "STRING",
      "enum": ["NEW_SCENARIO"]
    },
    "scenarioKey": {
      "type": "STRING",
      "pattern": "^[A-Z0-9_]+$"
    },
    "parentPath": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "status": {
      "type": "STRING",
      "enum": ["ACTIVE", "DRAFT", "DEPRECATED"]
    },
    "owner": {
      "type": "STRING"
    },
    "workflow": {
      "type": "STRING"
    },
    "outcome": {
      "type": "STRING"
    },
    "knowledge": {
      "type": "OBJECT"
    },
    "playbook": {
      "type": "OBJECT"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KnowledgeUpdate",
  "type": "OBJECT",
  "required": ["submissionType", "scenarioKey", "changes", "reason"],
  "properties": {
    "submissionType": {
      "type": "STRING",
      "enum": ["UPDATE"]
    },
    "scenarioKey": {
      "type": "STRING",
      "pattern": "^[A-Z0-9_]+$"
    },
    "changes": {
      "type": "OBJECT"
    },
    "reason": {
      "type": "STRING"
    }
  }
}

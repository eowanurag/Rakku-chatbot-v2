datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Citizen {
  id               String    @id @default(cuid())
  fullName         String
  mobileNumber     String
  email            String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  district         String?
  state            String?
  pincode          String?
  latitude         Float?
  longitude        Float?
  isConfirmed      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  complaints       Complaint[]
  verifications    Verification[]
  certificates     CharacterCertificate[]
  permissions      EventPermission[]
}

model Complaint {
  id              String   @id @default(uuid())
  referenceNumber String   @unique
  citizenId       String
  citizen         Citizen  @relation(fields: [citizenId], references: [id])
  complaintType   String
  incidentDetails String
  status          String   @default("Submitted")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Verification {
  id              String   @id @default(uuid())
  referenceNumber String   @unique
  citizenId       String
  citizen         Citizen  @relation(fields: [citizenId], references: [id])
  verificationType String  // Tenant, PG, Domestic Help, Employee
  name            String
  address         String
  mobile          String
  propertyDetails String
  status          String   @default("Submitted")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CharacterCertificate {
  id              String   @id @default(uuid())
  referenceNumber String   @unique
  citizenId       String
  citizen         Citizen  @relation(fields: [citizenId], references: [id])
  name            String
  address         String
  district        String
  purpose         String
  status          String   @default("Submitted")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EventPermission {
  id                 String   @id @default(uuid())
  referenceNumber    String   @unique
  citizenId          String
  citizen            Citizen  @relation(fields: [citizenId], references: [id])
  eventType          String   // Event Permission, Procession Request, Protest Request, Film Shooting Request
  eventName          String
  location           String
  date               String
  expectedAttendance Int
  status             String   @default("Submitted")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ChatHistory {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // user or assistant
  message   String
  createdAt DateTime @default(now())
}

model KnowledgeItem {
  id        String   @id @default(uuid())
  category  String
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model WorkflowSession {
  id                String   @id @default(uuid())
  citizenId         String?
  serviceType       String?
  currentStep       String
  stateJson         Json
  isCompleted       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

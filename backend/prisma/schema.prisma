generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  id                   String                 @id @default(cuid())
  fullName             String
  mobileNumber         String
  email                String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  district             String?
  state                String?
  pincode              String?
  latitude             Float?
  longitude            Float?
  locality             String?
  /// @deprecated Deprecated in Staging. Removal planned in V1 Release Candidate.
  nearestPoliceStation String?
  isConfirmed          Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  certificates         CharacterCertificate[]
  complaints           Complaint[]
  permissions          EventPermission[]
  verifications        Verification[]
  notifications        Notification[]
}

model Complaint {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  complaintType            String
  incidentDetails          String
  status                   String                  @default("Submitted")
  mobileBrand              String?
  mobileModel              String?
  mobileColor              String?
  purchaseYear             Int?
  imeiNumber               String?
  jurisdictionResolutionId String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])
}

model Verification {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  verificationType         String
  name                     String
  address                  String
  mobile                   String
  propertyDetails          String
  status                   String                  @default("Submitted")
  jurisdictionResolutionId String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])
}

model CharacterCertificate {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  name                     String
  address                  String
  district                 String
  purpose                  String
  status                   String                  @default("Submitted")
  jurisdictionResolutionId String?
  usedProfileReuse         Boolean                 @default(false)
  profileSnapshot          Json?
  profileSnapshotVersion   Int                     @default(1)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])
}

model EventPermission {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  eventType                String
  eventName                String
  location                 String
  date                     String
  expectedAttendance       Int
  status                   String                  @default("Submitted")
  organizerName            String?
  organizerAddress         String?
  organizerMobile          String?
  organizerIsApplicant     Boolean                 @default(true)
  jurisdictionResolutionId String?
  usedProfileReuse         Boolean                 @default(false)
  profileSnapshot          Json?
  profileSnapshotVersion   Int                     @default(1)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])
}

model ChatHistory {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  message   String
  createdAt DateTime @default(now())
}

model KnowledgeItem {
  id        String   @id @default(uuid())
  category  String
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model WorkflowSession {
  id          String   @id @default(uuid())
  citizenId   String?
  serviceType String?
  currentStep String
  stateJson   Json
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  sessionId   String
  eventType   String
  eventData   Json
  createdAt   DateTime @default(now())
}

model TrackingRecord {
  id                String   @id @default(cuid())
  referenceNumber   String   @unique
  serviceType       String
  entityId          String
  citizenId         String?
  currentStatus     String
  statusHistory     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ConversationInsight {
  id              String   @id @default(uuid())
  sessionId       String
  citizenId       String?
  workflowType    String?
  detectedIntent  String
  confidenceScore Float
  language        String
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model ConversationSentiment {
  id           String   @id @default(uuid())
  sessionId    String
  sentiment    String
  emotion      String
  workflowType String?
  createdAt    DateTime @default(now())
}


model UnansweredQuestion {
  id        String   @id @default(uuid())
  question  String   @unique
  language  String
  frequency Int      @default(1)
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model IntentTrainingData {
  id             String   @id @default(uuid())
  phrase         String
  language       String
  detectedIntent String
  verifiedIntent String?
  confidence     Float
  createdAt      DateTime @default(now())
}

model WorkflowAnalytics {
  id           String   @id @default(uuid())
  workflowType String
  stepName     String
  completed    Boolean  @default(false)
  abandoned    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model CitizenPreference {
  id                String   @id @default(uuid())
  citizenId         String   @unique
  preferredLanguage String
  preferredDistrict String?
  lastWorkflow      String?
  lastVisit         DateTime @default(now())
  createdAt         DateTime @default(now())
}

model KnowledgeCategory {
  id       String             @id @default(uuid())
  name     String             @unique
  articles KnowledgeArticle[]
}

model KnowledgeArticle {
  id              String            @id @default(uuid())
  categoryId      String
  title           String
  content         String
  language        String
  helpfulCount    Int               @default(0)
  notHelpfulCount Int               @default(0)
  updatedAt       DateTime          @updatedAt
  category        KnowledgeCategory @relation(fields: [categoryId], references: [id])
}

model LearningEvent {
  id        String   @id @default(uuid())
  eventType String
  severity  String
  details   Json
  createdAt DateTime @default(now())
}

model AggregatedMetric {
  id        String   @id @default(uuid())
  metricKey String
  value     Json
  createdAt DateTime @default(now())
}

model CitizenFeedback {
  id           String   @id @default(uuid())
  sessionId    String
  citizenId    String?
  workflowType String?
  rating       Int
  comments     String?
  category     String?
  subcategory  String?
  createdAt    DateTime @default(now())
}

// --- JURISDICTION & ROUTING PLATFORM ENUMS ---

enum RoutingTargetType {
  POLICE_STATION
  CYBER_CELL
  VERIFICATION_UNIT
  OTHER
}

enum ResolutionStatus {
  PENDING
  CONFIRMED
  OVERRIDDEN
  EXPIRED
}

enum RoutingDecision {
  AUTO_ASSIGNED
  USER_CONFIRMED
  USER_SELECTED
  FALLBACK_ASSIGNED
}

enum MatchType {
  EXACT
  ALIAS
  FUZZY
  MULTIPLE
  NONE
}

enum ResolutionSource {
  GPS
  TEXT_INPUT
  PROFILE_ADDRESS
  EVENT_LOCATION
  PROPERTY_ADDRESS
  MANUAL_SELECTION
}

enum ActorType {
  CITIZEN
  OFFICER
  SYSTEM
  ADMIN
  FASTAPI
  NESTJS
}

// --- JURISDICTION & ROUTING PLATFORM MODELS ---

model PoliceStation {
  id            String                 @id @default(uuid())
  stationCode   String                 @unique
  name          String
  districtCode  String
  cityCode      String?
  localityCode  String?
  latitude      Float?
  longitude     Float?
  phone         String?
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  mappings      JurisdictionMapping[]
  resolutions   JurisdictionResolution[]
}

model JurisdictionRegistryVersion {
  id          String                @id @default(uuid())
  version     String                @unique
  description String?
  createdAt   DateTime              @default(now())
  mappings    JurisdictionMapping[]
}

model JurisdictionMapping {
  id                String                      @id @default(uuid())
  districtCode      String
  cityCode          String?
  localityCode      String?
  policeStationId   String
  priority          Int                         @default(1)
  registryVersionId String
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  policeStation     PoliceStation               @relation(fields: [policeStationId], references: [id])
  registryVersion   JurisdictionRegistryVersion @relation(fields: [registryVersionId], references: [id])
}

model JurisdictionResolution {
  id                  String                          @id @default(uuid())
  routingTargetType   RoutingTargetType
  routingTargetId     String
  policeStationId     String?
  serviceType         String
  workflowId          String?
  routingContext      RoutingContext
  sourceLocation      Json
  resolutionSource    ResolutionSource
  confidence          Float
  matchType           MatchType
  routingDecision     RoutingDecision
  status              ResolutionStatus
  jurisdictionVersion String
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  policeStation       PoliceStation?                  @relation(fields: [policeStationId], references: [id])
  history             JurisdictionResolutionHistory[]
  events              JurisdictionResolutionEvent[]
  
  // Relations to workflows
  complaints          Complaint[]
  verifications       Verification[]
  certificates        CharacterCertificate[]
  permissions         EventPermission[]
}

model JurisdictionResolutionHistory {
  id                        String                 @id @default(uuid())
  jurisdictionResolutionId  String
  previousStatus            ResolutionStatus?
  newStatus                 ResolutionStatus
  previousStationId         String?
  newStationId              String?
  previousTargetType        RoutingTargetType?
  previousTargetId          String?
  newTargetType             RoutingTargetType?
  newTargetId               String?
  reason                    String?
  actorType                 ActorType?
  actorId                   String?
  changedAt                 DateTime               @default(now())
  jurisdictionResolution    JurisdictionResolution @relation(fields: [jurisdictionResolutionId], references: [id])
}

model JurisdictionResolutionEvent {
  id                        String                 @id @default(uuid())
  jurisdictionResolutionId  String
  eventType                 ResolutionEventType
  actorType                 ActorType?
  actorId                   String?
  metadata                  Json?
  createdAt                 DateTime               @default(now())
  jurisdictionResolution    JurisdictionResolution @relation(fields: [jurisdictionResolutionId], references: [id])
}

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model Notification {
  id            String               @id @default(uuid())
  citizenId     String?
  citizen       Citizen?             @relation(fields: [citizenId], references: [id])
  channel       NotificationChannel
  status        NotificationStatus
  template      String
  workflowType  String?
  workflowId    String?
  metadata      Json?
  createdAt     DateTime             @default(now())
  sentAt        DateTime?
}

enum RoutingContext {
  INCIDENT_LOCATION
  APPLICANT_ADDRESS
  PROPERTY_ADDRESS
  EVENT_LOCATION
  WORKPLACE_ADDRESS
  OTHER
}

enum ResolutionEventType {
  RESOLUTION_CREATED
  AUTO_ASSIGNED
  USER_CONFIRMED
  USER_SELECTED
  FALLBACK_ASSIGNED
  OVERRIDDEN
  EXPIRED
}

model SubmissionFingerprint {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  citizenId   String?
  serviceType String
  createdAt   DateTime @default(now())

  @@index([citizenId])
  @@index([serviceType])
  @@index([createdAt])
}



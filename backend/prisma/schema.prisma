generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  id                   String                 @id @default(cuid())
  fullName             String
  mobileNumber         String                 @unique
  email                String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  district             String?
  state                String?
  pincode              String?
  latitude             Float?
  longitude            Float?
  locality             String?
  /// @deprecated Deprecated in Staging. Removal planned in V1 Release Candidate.
  nearestPoliceStation String?
  isConfirmed          Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  certificates         CharacterCertificate[]
  complaints           Complaint[]
  permissions          EventPermission[]
  notifications        Notification[]
  verifications        Verification[]

  @@index([createdAt])
  @@index([updatedAt])
}

model Complaint {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  complaintType            String
  incidentDetails          String
  status                   String                  @default("Submitted")
  mobileBrand              String?
  mobileModel              String?
  mobileColor              String?
  purchaseYear             Int?
  imeiNumber               String?
  jurisdictionResolutionId String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])

  @@index([citizenId, referenceNumber, status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([citizenId, status])
}

model Verification {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  verificationType         String
  name                     String
  address                  String
  mobile                   String
  propertyDetails          String
  status                   String                  @default("Submitted")
  jurisdictionResolutionId String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])

  @@index([citizenId])
  @@index([createdAt])
  @@index([updatedAt])
}

model CharacterCertificate {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  name                     String
  address                  String
  district                 String
  purpose                  String
  status                   String                  @default("Submitted")
  jurisdictionResolutionId String?
  usedProfileReuse         Boolean                 @default(false)
  profileSnapshot          Json?
  profileSnapshotVersion   Int                     @default(1)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])

  @@index([citizenId])
  @@index([createdAt])
  @@index([updatedAt])
}

model EventPermission {
  id                       String                  @id @default(uuid())
  referenceNumber          String                  @unique
  citizenId                String
  eventType                String
  eventName                String
  location                 String
  date                     String
  expectedAttendance       Int
  status                   String                  @default("Submitted")
  organizerName            String?
  organizerAddress         String?
  organizerMobile          String?
  organizerIsApplicant     Boolean                 @default(true)
  jurisdictionResolutionId String?
  usedProfileReuse         Boolean                 @default(false)
  profileSnapshot          Json?
  profileSnapshotVersion   Int                     @default(1)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  citizen                  Citizen                 @relation(fields: [citizenId], references: [id])
  jurisdictionResolution   JurisdictionResolution? @relation(fields: [jurisdictionResolutionId], references: [id])

  @@index([citizenId])
  @@index([createdAt])
  @@index([updatedAt])
}

model ChatHistory {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  message   String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model KnowledgeItem {
  id        String   @id @default(uuid())
  category  String
  question  String
  answer    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model WorkflowSession {
  id          String   @id @default(uuid())
  citizenId   String?
  serviceType String?
  currentStep String
  stateJson   Json
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([citizenId, serviceType, isCompleted])
  @@index([createdAt])
  @@index([updatedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  sessionId String
  eventType String
  eventData Json
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([eventType])
  @@index([createdAt])
}

model TrackingRecord {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  serviceType     String
  entityId        String
  citizenId       String?
  currentStatus   String
  statusHistory   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([citizenId])
  @@index([createdAt])
  @@index([updatedAt])
}

model ConversationInsight {
  id              String   @id @default(uuid())
  sessionId       String
  citizenId       String?
  workflowType    String?
  detectedIntent  String
  confidenceScore Float
  language        String
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([citizenId])
  @@index([createdAt])
}

model ConversationSentiment {
  id           String   @id @default(uuid())
  sessionId    String
  sentiment    String
  emotion      String
  workflowType String?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model UnansweredQuestion {
  id        String   @id @default(uuid())
  question  String   @unique
  language  String
  frequency Int      @default(1)
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model IntentTrainingData {
  id             String   @id @default(uuid())
  phrase         String
  language       String
  detectedIntent String
  verifiedIntent String?
  confidence     Float
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model WorkflowAnalytics {
  id           String   @id @default(uuid())
  workflowType String
  stepName     String
  completed    Boolean  @default(false)
  abandoned    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model CitizenPreference {
  id                String   @id @default(uuid())
  citizenId         String   @unique
  preferredLanguage String
  preferredDistrict String?
  lastWorkflow      String?
  lastVisit         DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([createdAt])
}

model KnowledgeCategory {
  id       String             @id @default(uuid())
  name     String             @unique
  articles KnowledgeArticle[]
}

model KnowledgeArticle {
  id              String            @id @default(uuid())
  categoryId      String
  title           String
  content         String
  language        String
  helpfulCount    Int               @default(0)
  notHelpfulCount Int               @default(0)
  updatedAt       DateTime          @updatedAt
  category        KnowledgeCategory @relation(fields: [categoryId], references: [id])

  @@index([updatedAt])
}

model LearningEvent {
  id        String   @id @default(uuid())
  eventType String
  severity  String
  details   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AggregatedMetric {
  id        String   @id @default(uuid())
  metricKey String
  value     Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model CitizenFeedback {
  id           String   @id @default(uuid())
  sessionId    String
  citizenId    String?
  workflowType String?
  rating       Int
  comments     String?
  category     String?
  subcategory  String?
  createdAt    DateTime @default(now())

  @@index([citizenId, createdAt])
  @@index([sessionId])
}

model PoliceStation {
  id           String                   @id @default(uuid())
  stationCode  String                   @unique
  name         String
  districtCode String
  cityCode     String?
  localityCode String?
  latitude     Float?
  longitude    Float?
  phone        String?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  mappings     JurisdictionMapping[]
  resolutions  JurisdictionResolution[]

  @@index([createdAt])
  @@index([updatedAt])
}

model JurisdictionRegistryVersion {
  id          String                @id @default(uuid())
  version     String                @unique
  description String?
  createdAt   DateTime              @default(now())
  mappings    JurisdictionMapping[]

  @@index([createdAt])
}

model JurisdictionMapping {
  id                String                      @id @default(uuid())
  districtCode      String
  cityCode          String?
  localityCode      String?
  policeStationId   String
  priority          Int                         @default(1)
  registryVersionId String
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  policeStation     PoliceStation               @relation(fields: [policeStationId], references: [id])
  registryVersion   JurisdictionRegistryVersion @relation(fields: [registryVersionId], references: [id])

  @@index([createdAt])
  @@index([updatedAt])
}

model JurisdictionResolution {
  id                  String                          @id @default(uuid())
  routingTargetType   RoutingTargetType
  routingTargetId     String
  policeStationId     String?
  serviceType         String
  workflowId          String?
  routingContext      RoutingContext
  sourceLocation      Json
  resolutionSource    ResolutionSource
  confidence          Float
  matchType           MatchType
  routingDecision     RoutingDecision
  status              ResolutionStatus
  jurisdictionVersion String
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  certificates        CharacterCertificate[]
  complaints          Complaint[]
  permissions         EventPermission[]
  policeStation       PoliceStation?                  @relation(fields: [policeStationId], references: [id])
  events              JurisdictionResolutionEvent[]
  history             JurisdictionResolutionHistory[]
  verifications       Verification[]
}

model JurisdictionResolutionHistory {
  id                       String                 @id @default(uuid())
  jurisdictionResolutionId String
  previousStatus           ResolutionStatus?
  newStatus                ResolutionStatus
  previousStationId        String?
  newStationId             String?
  previousTargetType       RoutingTargetType?
  previousTargetId         String?
  newTargetType            RoutingTargetType?
  newTargetId              String?
  reason                   String?
  actorType                ActorType?
  actorId                  String?
  changedAt                DateTime               @default(now())
  jurisdictionResolution   JurisdictionResolution @relation(fields: [jurisdictionResolutionId], references: [id])
}

model JurisdictionResolutionEvent {
  id                       String                 @id @default(uuid())
  jurisdictionResolutionId String
  eventType                ResolutionEventType
  actorType                ActorType?
  actorId                  String?
  metadata                 Json?
  createdAt                DateTime               @default(now())
  jurisdictionResolution   JurisdictionResolution @relation(fields: [jurisdictionResolutionId], references: [id])
}

model Notification {
  id           String              @id @default(uuid())
  citizenId    String?
  channel      NotificationChannel
  status       NotificationStatus
  template     String
  workflowType String?
  workflowId   String?
  metadata     Json?
  createdAt    DateTime            @default(now())
  sentAt       DateTime?
  citizen      Citizen?            @relation(fields: [citizenId], references: [id])
}

model SubmissionFingerprint {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  citizenId   String?
  serviceType String
  createdAt   DateTime @default(now())

  @@index([citizenId])
  @@index([serviceType])
  @@index([createdAt])
}

model IntentClassification {
  id                           String   @id @default(uuid())
  sessionId                    String
  assessmentVersion            Int      @default(1)
  parentAssessmentId           String?
  rawNarrative                 String
  predictedIntent              String
  citizenSelectedIntent        String?
  citizenSelectedService       String?
  incidentCategory             String?
  recommendedServices          Json
  recommendedActions           Json
  confidence                   Float
  confidenceBand               String
  recommendationConfidence     Float
  recommendationConfidenceBand String
  urgency                      String
  assessmentStatus             String
  storyCompleteness            Float
  detectedEntities             Json?
  reasoning                    Json
  cueMetadata                  Json?
  cueVersion                   String?
  createdAt                    DateTime @default(now())

  @@index([sessionId])
  @@index([predictedIntent])
  @@index([createdAt])
}

model SituationAssessmentSession {
  id                    String   @id @default(uuid())
  sessionId             String   @unique
  latestIntent          String
  latestConfidence      Float
  assessmentStatus      String
  clarificationRequired Boolean
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sessionId])
  @@index([createdAt])
  @@index([updatedAt])
}

model ComplaintSession {
  id                    String   @id @default(uuid())
  sessionId             String   @unique
  incidentType          String?
  readinessScore        Float    @default(0)
  status                String
  clarificationRequired Boolean
  draftApproved         Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sessionId])
  @@index([createdAt])
  @@index([updatedAt])
}

model ComplaintAssessment {
  id                      String   @id @default(uuid())
  sessionId               String
  factVersion             Int      @default(1)
  parentAssessmentId      String?
  incidentType            String
  complaintReadinessScore Float
  firReadinessScore       Float
  structuredPayload       Json
  extractedFacts          Json
  narrativeSnapshots      Json?
  draftText               String
  createdAt               DateTime @default(now())

  @@index([sessionId])
  @@index([incidentType])
  @@index([createdAt])
}

enum RoutingTargetType {
  POLICE_STATION
  CYBER_CELL
  VERIFICATION_UNIT
  OTHER
}

enum ResolutionStatus {
  PENDING
  CONFIRMED
  OVERRIDDEN
  EXPIRED
}

enum RoutingDecision {
  AUTO_ASSIGNED
  USER_CONFIRMED
  USER_SELECTED
  FALLBACK_ASSIGNED
}

enum MatchType {
  EXACT
  ALIAS
  FUZZY
  MULTIPLE
  NONE
}

enum ResolutionSource {
  GPS
  TEXT_INPUT
  PROFILE_ADDRESS
  EVENT_LOCATION
  PROPERTY_ADDRESS
  MANUAL_SELECTION
}

enum ActorType {
  CITIZEN
  OFFICER
  SYSTEM
  ADMIN
  FASTAPI
  NESTJS
}

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum RoutingContext {
  INCIDENT_LOCATION
  APPLICANT_ADDRESS
  PROPERTY_ADDRESS
  EVENT_LOCATION
  WORKPLACE_ADDRESS
  OTHER
}

enum ResolutionEventType {
  RESOLUTION_CREATED
  AUTO_ASSIGNED
  USER_CONFIRMED
  USER_SELECTED
  FALLBACK_ASSIGNED
  OVERRIDDEN
  EXPIRED
}

model ScenarioSession {
  id                    String   @id @default(uuid())
  sessionId             String   @unique

  currentScenario       String?
  currentState          String?

  clarificationCount    Int      @default(0)
  askedQuestions        Json?    // History of questions to prevent loops

  outcomeSelected       Boolean  @default(false)
  currentNode           String?
  scenarioRevision      Int      @default(1)
  activeScenarioPath    Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
}

model ScenarioAssessment {
  id                      String   @id @default(uuid())
  sessionId               String

  assessmentVersion       Int      @default(1)
  parentAssessmentId      String?

  scenario                String
  scenarioPath            Json?    // Stores reasoning path, e.g. ["LOSS", "DOCUMENT", "AADHAAR"]
  scenarioHints           Json?
  scenarioCompleteness    Float?

  outcome                 String
  goal                    String
  riskLevel               String

  confidence              Float
  scenarioConfidence      Float?
  confidenceHistory       Json?
  reasoningSummary        Json?

  actionPlan              Json
  resolutionSource        String?  // Analytics (e.g. GRAPH_ONLY, OFFICER_REVIEW)
  graphVersion            String?
  graphHash               String?
  resolutionQuality       String?
  hintConfidenceBreakdown Json?

  createdAt               DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model UnderstandingCandidate {
  id                 String    @id @default(uuid())
  term               String
  occurrences        Int       @default(1)
  sampleNarrative    String
  suggestedMeaning   String?
  status             String    // PENDING, APPROVED, REJECTED, EXPORTED
  priority           String    @default("LOW")
  relatedIntent      String?
  aiReviewQueued     Boolean   @default(false)
  promotedToTerm     Boolean   @default(false)
  approvedBy         String?
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())

  @@index([createdAt])
}

model UnderstandingTerm {
  id              String    @id @default(uuid())
  term            String    @unique
  meaning         String
  source          String    // SYNONYM, DIALECT, ABBREVIATION
  version         String
  evidenceCount   Int       @default(1)
  exportedVersion String?
  exportedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([createdAt])
}

model UnderstandingReviewQueue {
  id            String   @id @default(uuid())
  candidateId   String
  reviewType    String
  status        String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model CueReplayResult {
  id               String   @id @default(uuid())
  replayVersion    String
  oldVersion       String
  newVersion       String
  improvementScore Float
  createdAt        DateTime @default(now())

  @@index([createdAt])
}

model ScenarioGraphCandidate {
  id           String   @id @default(uuid())
  parentNode   String
  proposedNode String
  occurrences  Int      @default(1)
  status       String   // PENDING, APPROVED, REJECTED
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model WorkflowCompletionMetrics {
  id                   String   @id @default(uuid())
  sessionId            String
  workflowType         String
  completionPercentage Float
  abandonmentRisk      String
  completed            Boolean
  createdAt            DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model DraftRecoveryEvent {
  id            String   @id @default(uuid())
  sessionId     String
  recovered     Boolean
  recoveredStep String?
  recoveredAt   DateTime @default(now())

  @@index([sessionId])
  @@index([recoveredAt])
}

model OfflineSyncEvent {
  id           String   @id @default(uuid())
  syncId       String
  eventType    String
  payloadSize  Int
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([syncId])
  @@index([createdAt])
}

model CitizenRecommendationEvent {
  id                 String   @id @default(uuid())
  sessionId          String
  recommendationType String
  accepted           Boolean
  createdAt          DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model CitizenWorkflowEvent {
  id           String   @id @default(uuid())
  sessionId    String
  workflowType String
  eventType    String
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}



